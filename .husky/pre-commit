#!/bin/sh

# Pre-commit hook para food-service
# Executa lint, typecheck e testes antes de permitir o commit

echo "🛡️ Pre-commit checks running..."

# Cores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Função para exibir erros
error_exit() {
    echo "${RED}❌ $1${NC}"
    exit 1
}

# Função para exibir sucesso
success_msg() {
    echo "${GREEN}✅ $1${NC}"
}

# Ignora arquivos node_modules e gerados
files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(ts|tsx|js|jsx)$' | grep -v node_modules || true)

if [ -z "$files" ]; then
    success_msg "Nenhum arquivo TypeScript/JavaScript para verificar"
    exit 0
fi

echo "📁 Arquivos modificados:"
echo "$files"
echo ""

# 1. Lint com Biome
echo "🔍 1/3 Verificando código com Biome..."
npx @biomejs/biome check src/ --error-on-warnings 2>&1
if [ $? -ne 0 ]; then
    error_exit "Lint falhou! Corrija os erros acima antes de commitar."
fi
success_msg "Lint passou"

# 2. Build (verifica erros de TypeScript)
echo "🔧 2/3 Verificando build..."
npm run build 2>&1 | tail -20
if [ $? -ne 0 ]; then
    error_exit "Build falhou! Corrija os erros de TypeScript."
fi
success_msg "Build passou"

# 3. Execução rápida de testes
echo "🧪 3/3 Rodando testes..."
npm test -- --run 2>&1 | tail -10
if [ $? -ne 0 ]; then
    error_exit "Testes falharam! Corrija antes de commitar."
fi
success_msg "Testes passaram"

echo ""
success_msg "Todos os checks passaram! Commit permitido."
exit 0
