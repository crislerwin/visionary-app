# ============================================================
# Visionary — Exemplo de variáveis de ambiente para Docker
# Copie para .env e preencha os valores reais
# NUNCA commite o .env real no git
# ============================================================

# Base
NODE_ENV=production

# Database (PostgreSQL)
# O docker-compose.yml monta a DATABASE_URL automaticamente a partir de:
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=visionary

# NextAuth.js / Auth.js v5
AUTH_SECRET=your-super-secret-key-change-this-in-production
AUTH_URL=http://localhost:3000

# OAuth Providers (Optional)
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Redis (Optional - for future features)
REDIS_URL=redis://localhost:6379

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4318/v1/traces
OTEL_SERVICE_NAME=visionary

# Logging
LOG_LEVEL=info

# Pluggy (Open Finance)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
NEXT_PUBLIC_PLUGGY_CONFIGURED=true

# Grafana (LGTM stack)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Docker Hub (opcional — usado pelo Taskfile)
DOCKER_HUB_USER=seu-usuario
