# ============================================================
# Base
# ============================================================
NODE_ENV=production

# ============================================================
# App / Next.js
# ============================================================
PORT=3000
HOSTNAME=0.0.0.0
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production

# ============================================================
# Database
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=saas
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ============================================================
# Storage Provider (local | minio | s3)
# ============================================================
STORAGE_PROVIDER=s3

# ============================================================
# AWS S3
# ============================================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=meu-rango-images
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# AWS_S3_ENDPOINT=

# ============================================================
# MinIO (S3-compatible object storage)
# ============================================================
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_PUBLIC_ENDPOINT=https://minio.seudominio.com
# MINIO_BUCKET=food-service-images
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================================
# Grafana
# ============================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================
# Observability / OpenTelemetry
# ============================================================
OTEL_SERVICE_NAME=meu-rango
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-lgtm:4318/v1/traces
LOG_LEVEL=info

# ============================================================
# Docker Hub
# ============================================================
DOCKER_HUB_USER=seu-usuario-dockerhub

# ============================================================
# OAuth Providers (opcional)
# ============================================================
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
