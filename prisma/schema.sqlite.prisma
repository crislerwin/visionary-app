generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  tenantId     String?  @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@map("sessions")
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime? @map("email_verified")
  image          String?
  password       String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  ownedTenants  Tenant[]     @relation("TenantOwner")
  posts         Post[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  ownerId     String   @map("owner_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner             User              @relation("TenantOwner", fields: [ownerId], references: [id])
  memberships       Membership[]
  sessions          Session[]
  posts             Post[]
  bankAccounts      BankAccount[]
  categories        Category[]
  pluggyConnections PluggyConnection[]
  dataSources       DataSource[]
  partners          Partner[]
  partnerInvoices   PartnerInvoice[]
  alertRules        AlertRule[]
  notifications     Notification[]

  @@map("tenants")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Membership {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  tenantId  String     @map("tenant_id")
  role      MemberRole @default(MEMBER)
  invitedAt DateTime   @default(now()) @map("invited_at")
  joinedAt  DateTime?  @map("joined_at")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("memberships")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String   @map("author_id")
  tenantId  String   @map("tenant_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author User   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([authorId])
  @@map("posts")
}

// ====================
// FINANCIAL MODELS
// ====================

enum BankAccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  DIGITAL_WALLET
  OTHER
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  COMPLETED
  PENDING
  CANCELLED
}

enum DataSourceType {
  PLUGGY
  WEBHOOK
  CSV
  XLSX
}

enum DataSourceStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

model BankAccount {
  id              String          @id @default(cuid())
  name            String
  bankName        String?         @map("bank_name")
  type            BankAccountType
  currency        String          @default("BRL")
  initialBalance  Decimal         @map("initial_balance")
  currentBalance  Decimal         @map("current_balance")
  tenantId        String          @map("tenant_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([tenantId])
  @@map("bank_accounts")
}

model Category {
  id          String       @id @default(cuid())
  name        String
  type        CategoryType
  color       String       @default("#6366F1")
  icon        String       @default("circle")
  tenantId    String       @map("tenant_id")
  parentId    String?      @map("parent_id")
  isDefault   Boolean      @default(false) @map("is_default")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     Category[]    @relation("CategoryParent")
  transactions Transaction[]

  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

model Transaction {
  id            String           @id @default(cuid())
  amount        Decimal
  type          TransactionType
  description   String?
  date          DateTime
  bankAccountId String           @map("bank_account_id")
  categoryId    String?          @map("category_id")
  partnerId     String?          @map("partner_id")
  status        TransactionStatus @default(COMPLETED)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  partner     Partner?    @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([bankAccountId])
  @@index([categoryId])
  @@index([partnerId])
  @@index([date])
  @@index([status])
  @@map("transactions")
}

model PluggyConnection {
  id            String   @id @default(cuid())
  itemId        String   @map("item_id")
  connectorId   Int      @map("connector_id")
  connectorName String   @map("connector_name")
  status        String   @default("UPDATING")
  tenantId      String   @map("tenant_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([itemId, tenantId])
  @@index([tenantId])
  @@map("pluggy_connections")
}

model DataSource {
  id          String             @id @default(cuid())
  name        String
  type        DataSourceType
  status      DataSourceStatus   @default(ACTIVE)
  config      Json?
  tenantId    String             @map("tenant_id")
  lastSyncAt  DateTime?          @map("last_sync_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  webhookCalls WebhookCall[]

  @@unique([tenantId, type, name])
  @@index([tenantId])
  @@map("data_sources")
}

model WebhookCall {
  id        String   @id @default(cuid())
  sourceId  String   @map("source_id")
  payload   Json
  status    Int
  createdAt DateTime @default(now()) @map("created_at")

  source DataSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@map("webhook_calls")
}

// ====================
// PARTNER MODELS
// ====================

enum PartnerType {
  SUPPLIER
  AFFILIATE
  DISTRIBUTOR
  SERVICE_PROVIDER
  OTHER
}

enum PartnerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CommissionType {
  PERCENTAGE
  FIXED
  HYBRID
}

enum PartnerInvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Partner {
  id              String        @id @default(cuid())
  name            String
  type            PartnerType
  email           String?
  phone           String?
  document        String?
  pixKey          String?       @map("pix_key")
  bankName        String?       @map("bank_name")
  bankAgency      String?       @map("bank_agency")
  bankAccount     String?       @map("bank_account")
  bankAccountType String?       @map("bank_account_type")
  commissionType  CommissionType @default(PERCENTAGE) @map("commission_type")
  commissionValue Decimal       @default(0) @map("commission_value")
  status          PartnerStatus @default(ACTIVE)
  notes           String?
  tenantId        String        @map("tenant_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoices      PartnerInvoice[]
  transactions  Transaction[]

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([name])
  @@map("partners")
}

model PartnerInvoice {
  id           String               @id @default(cuid())
  partnerId    String               @map("partner_id")
  description  String?
  amount       Decimal
  dueDate      DateTime             @map("due_date")
  paidAt       DateTime?            @map("paid_at")
  status       PartnerInvoiceStatus @default(PENDING)
  reference    String?
  notes        String?
  tenantId     String               @map("tenant_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([tenantId])
  @@index([status])
  @@index([dueDate])
  @@map("partner_invoices")
}

// ====================
// ALERT / NOTIFICATION MODELS
// ====================

model AlertRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  condition   String   // "balance_below", "invoice_overdue", "revenue_target"
  threshold   Decimal  @default(0)
  targetType  String?  @map("target_type") // "BANK_ACCOUNT", "PARTNER_INVOICE"
  targetId    String?  @map("target_id")
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  isActive    Boolean  @default(true) @map("is_active")
  tenantId    String   @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([tenantId])
  @@index([isActive])
  @@map("alert_rules")
}

model Notification {
  id          String            @id @default(cuid())
  alertRuleId String            @map("alert_rule_id")
  title       String
  message     String
  status      String            @default("UNREAD") // UNREAD, READ, DISMISSED
  data        String?             // snapshot data (balance, etc)
  userId      String            @map("user_id")
  tenantId    String            @map("tenant_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  readAt      DateTime?         @map("read_at")
  dismissedAt DateTime?         @map("dismissed_at")

  alertRule AlertRule @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([alertRuleId])
  @@index([userId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}
